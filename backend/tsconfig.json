{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "emitDecoratorMetadata": true, // Required for TypeORM
    "experimentalDecorators": true // Required for TypeORM
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
