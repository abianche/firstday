# PostgreSQL Database Configuration
DB_HOST=localhost               # Replace with your database host, e.g., localhost or a Docker service name
DB_PORT=5432                    # Default PostgreSQL port
DB_USER=your_database_user      # Replace with your database username
DB_PASSWORD=your_database_password  # Replace with your database password
DB_NAME=your_database_name      # Replace with your database name

# JWT Secret Key (for token generation)
JWT_SECRET=your_jwt_secret      # Replace with a secure, random secret for JWT signing

# TypeORM Configuration
TYPEORM_SYNC=true               # Set to true in development, false in production
TYPEORM_LOGGING=true            # Enable SQL logging (set to false in production)
